*.aab.idsig
*.apk.idsig
*.app
*.ipa
*.xcframework/
*.dSYM/
*.dSYM.zip
Resources/Raw/Trimmed*
Resources/Raw/Generated*
**/Resources/AppIcon/*.designer.cs

