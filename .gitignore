# ============================================================
# .NET MAUI .gitignore
# Covers: .NET / MSBuild, MAUI, iOS, Android, MacCatalyst, Windows
# IDEs: Visual Studio, Rider, VS Code, Visual Studio for Mac
# OS: macOS, Windows, Linux
# ============================================================

# ---------- Build output ----------
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Pp]ublish/
publish/
[Bb]uilds/
out/

# Generated XAML / source generators
*.g.cs
*.g.i.cs
*.designer.cs
GeneratedFiles/
**/Generated*/

# ---------- NuGet ----------
*.nupkg
*.snupkg
*.nuget.props
*.nuget.targets
**/[Pp]ackages/*
!**/[Pp]ackages/build/
project.lock.json
project.fragment.lock.json
artifacts/
.nuget/
.config/dotnet-tools.json.user

# ---------- .NET intermediate ----------
*.pdb
*.dll.config
*.exe.config
*.suo
*.user
*.userprefs
*.userosscache
*.sln.docstates
*.binlog
*.fingerprint
.vs/
.vsconfig
*.lock.json

