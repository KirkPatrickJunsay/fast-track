<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FastTrack.ViewModels;assembly=FastTrack.Core"
             xmlns:h="clr-namespace:FastTrack.Helpers"
             x:Class="FastTrack.MainPage"
             x:DataType="vm:HomeViewModel"
             Title="Fast Track">

    <ScrollView Background="{StaticResource HomeAmbientBackground}">
        <VerticalStackLayout Padding="20,12,20,32" Spacing="18">

            <!-- GREETING -->
            <VerticalStackLayout Spacing="2" Margin="0,0,0,4">
                <Label Text="{Binding Greeting}" Style="{StaticResource HeadlineLg}" />
                <Label Text="{Binding SubGreeting}" Style="{StaticResource BodyMuted}" />
            </VerticalStackLayout>

            <!-- GAMIFICATION STRIP — streak + freezes + level/XP -->
            <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8"
                  IsVisible="{Binding ShowGamification}">
                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 999"
                        Stroke="{StaticResource OutlineVariant}"
                        StrokeThickness="1"
                        Background="{StaticResource SurfaceContainerLow}"
                        Padding="12,8"
                        VerticalOptions="Center">
                    <HorizontalStackLayout Spacing="6">
                        <Image Source="{Binding StreakFlameAsset}"
                               HeightRequest="20" WidthRequest="20"
                               VerticalOptions="Center" />
                        <Label Text="{Binding StreakChipText}"
                               FontAttributes="Bold" FontSize="13"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        StrokeShape="RoundRectangle 999"
                        Stroke="{StaticResource Secondary}"
                        StrokeThickness="1"
                        Background="{StaticResource SecondaryContainer}"
                        Padding="10,8"
                        VerticalOptions="Center"
                        IsVisible="{Binding HasFreezes}">
                    <HorizontalStackLayout Spacing="4">
                        <Label Text="❄" FontSize="13" VerticalOptions="Center"
                               TextColor="{StaticResource Secondary}" />
                        <Label Text="{Binding FreezesText}"
                               FontAttributes="Bold" FontSize="12"
                               TextColor="{StaticResource Secondary}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <Frame Grid.Column="2" Style="{StaticResource CardCompact}">
                    <VerticalStackLayout Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="{Binding LevelName}"
                                   FontAttributes="Bold" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding XpProgressText}"
                                   Style="{StaticResource BodyMuted}" FontSize="11"
                                   VerticalOptions="Center" />
                        </Grid>
                        <ProgressBar Progress="{Binding XpProgressFraction}" HeightRequest="4" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- TODAY HEALTH SUMMARY -->
            <Frame Style="{StaticResource Card}" IsVisible="{Binding ShowDailyHealth}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="TODAY" Style="{StaticResource LabelCaps}" />

                    <!-- Water -->
                    <VerticalStackLayout Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="💧 Water" FontAttributes="Bold" />
                            <HorizontalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <h:AnimatedNumberLabel Value="{Binding WaterTodayMl}"
                                                       Format="{}{0:0}"
                                                       Style="{StaticResource BodyMuted}" />
                                <Label Text="{Binding WaterGoalMl, StringFormat=' / {0} ml'}"
                                       Style="{StaticResource BodyMuted}" />
                            </HorizontalStackLayout>
                        </Grid>
                        <ProgressBar Progress="{Binding WaterFraction}" HeightRequest="6" />
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" Margin="0,4,0,0">
                            <Button Grid.Column="0" Text="+250 ml"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding AddWaterCommand}" CommandParameter="250" />
                            <Button Grid.Column="1" Text="+500 ml"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding AddWaterCommand}" CommandParameter="500" />
                            <Button Grid.Column="2" Text="+1 L"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding AddWaterCommand}" CommandParameter="1000" />
                        </Grid>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}" />

                    <!--
                        Mood + Weight side-by-side. Each column uses a locked Grid
                        (RowDefinitions=16,38,16,Auto) so the four rows — caps label,
                        value, sub-caption, button — stay vertically aligned even when
                        the value lengths differ (an emoji is taller than "—", the
                        delta caption can wrap to one or two lines, etc).
                    -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Grid Grid.Column="0" RowDefinitions="16,38,16,Auto" RowSpacing="6">
                            <Label Grid.Row="0" Text="MOOD" Style="{StaticResource LabelCaps}" VerticalOptions="Center" />
                            <Label Grid.Row="1" Text="{Binding LatestMoodEmoji}"
                                   FontSize="28" VerticalOptions="Center" />
                            <Label Grid.Row="2" Text="{Binding LatestMoodAgo}"
                                   Style="{StaticResource BodyMuted}" FontSize="11"
                                   LineBreakMode="TailTruncation" VerticalOptions="Center" />
                            <Button Grid.Row="3" Text="Log mood"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding OpenLogMoodCommand}"
                                    HorizontalOptions="Fill"
                                    Margin="0,4,0,0" />
                        </Grid>
                        <Grid Grid.Column="1" RowDefinitions="16,38,16,Auto" RowSpacing="6">
                            <Label Grid.Row="0" Text="WEIGHT" Style="{StaticResource LabelCaps}" VerticalOptions="Center" />
                            <Label Grid.Row="1" Text="{Binding LatestWeightDisplay}"
                                   FontSize="22" FontAttributes="Bold" VerticalOptions="Center" />
                            <Label Grid.Row="2" Text="{Binding WeightDeltaDisplay}"
                                   Style="{StaticResource BodyMuted}" FontSize="11"
                                   LineBreakMode="TailTruncation" VerticalOptions="Center" />
                            <Button Grid.Row="3" Text="Log weight"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding OpenLogWeightCommand}"
                                    HorizontalOptions="Fill"
                                    Margin="0,4,0,0" />
                        </Grid>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- TODAY'S QUESTS -->
            <Frame Style="{StaticResource Card}" IsVisible="{Binding ShowQuestsCard}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="TODAY'S QUESTS" Style="{StaticResource LabelCaps}" />
                    <CollectionView ItemsSource="{Binding Quests}" SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:QuestRowViewModel">
                                <VerticalStackLayout Spacing="4" Opacity="{Binding Opacity}">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <Label Grid.Column="0" Text="{Binding Title}"
                                               FontAttributes="Bold" FontSize="14" />
                                        <Label Grid.Column="1"
                                               Text="{Binding XpReward, StringFormat='+{0} XP'}"
                                               TextColor="{StaticResource Secondary}"
                                               FontSize="12" FontAttributes="Bold"
                                               VerticalOptions="Center" />
                                    </Grid>
                                    <Label Text="{Binding Description}"
                                           Style="{StaticResource BodyMuted}" FontSize="12" />
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <ProgressBar Grid.Column="0" Progress="{Binding Progress}" HeightRequest="4"
                                                     VerticalOptions="Center" />
                                        <Label Grid.Column="1" Text="{Binding ProgressText}"
                                               Style="{StaticResource BodyMuted}" FontSize="11"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- ACTIVE FAST hero: circular ring + centred elapsed time -->
            <Grid x:Name="RingContainer"
                  IsVisible="{Binding IsActive}"
                  HeightRequest="320"
                  Margin="0,8,0,0">
                <GraphicsView x:Name="FastingRingView" />
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
                    <Label Text="FASTING TIME"
                           Style="{StaticResource LabelCaps}"
                           HorizontalOptions="Center" />
                    <Label Text="{Binding ElapsedDisplay}"
                           Style="{StaticResource TimerDisplay}"
                           FontSize="44"
                           SemanticProperties.Description="{Binding ElapsedDisplay, StringFormat='Elapsed {0}'}" />
                    <Label Text="{Binding ProgressPercent}"
                           Style="{StaticResource BodyMuted}"
                           HorizontalOptions="Center" />
                    <Button Text="Edit start time / fasting plan"
                            Style="{StaticResource LinkButton}"
                            Command="{Binding EditActiveFastCommand}"
                            HorizontalOptions="Center"
                            Margin="0,6,0,0" />
                </VerticalStackLayout>
            </Grid>

            <!-- IDLE hero -->
            <Frame Style="{StaticResource Card}"
                   IsVisible="{Binding IsIdle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="READY TO FAST" Style="{StaticResource LabelCaps}" />
                    <Label Text="Tap Start to begin a fast." Style="{StaticResource BodyMd}" />
                    <Label Text="{Binding DefaultProtocolName, StringFormat='Default protocol · {0}'}"
                           Style="{StaticResource BodyMuted}"
                           Margin="0,4,0,0" />
                </VerticalStackLayout>
            </Frame>

            <!-- EATING WINDOW hero -->
            <Frame Style="{StaticResource CardSecondary}"
                   IsVisible="{Binding IsEatingWindow}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="EATING WINDOW"
                           Style="{StaticResource LabelCaps}"
                           TextColor="{StaticResource Secondary}" />
                    <Label Text="{Binding EatingWindowRemaining}"
                           Style="{StaticResource TimerDisplay}"
                           TextColor="{StaticResource Secondary}" />
                    <Label Text="remaining"
                           HorizontalTextAlignment="Center"
                           Style="{StaticResource BodyMuted}" />
                    <Label Text="{Binding EatingWindowEndsAt}"
                           HorizontalTextAlignment="Center"
                           Style="{StaticResource BodyMuted}" />
                </VerticalStackLayout>
            </Frame>

            <!-- CURRENT STAGE card -->
            <Frame Style="{StaticResource Card}" IsVisible="{Binding IsActive}">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 8"
                            Stroke="{StaticResource Primary}" StrokeThickness="0"
                            Background="{StaticResource PrimaryContainer}"
                            Padding="10"
                            HeightRequest="44" WidthRequest="44"
                            VerticalOptions="Start">
                        <Label Text="●"
                               TextColor="{StaticResource Primary}"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                        <Label Text="{Binding StageName}" Style="{StaticResource HeadlineMd}" />
                        <Label Text="{Binding StageSummary}" Style="{StaticResource BodyMuted}" />
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <!-- GOAL / REMAINING quick cards -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" IsVisible="{Binding ShowProgressGrid}">
                <Frame Grid.Column="0" Style="{StaticResource CardCompact}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="GOAL" Style="{StaticResource LabelCaps}" />
                        <Label Text="{Binding GoalDisplay}" Style="{StaticResource HeadlineMd}" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Column="1" Style="{StaticResource CardCompact}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="PROGRESS" Style="{StaticResource LabelCaps}" />
                        <Label Text="{Binding ProgressPercent}"
                               Style="{StaticResource HeadlineMd}"
                               TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- STAGES ROADMAP (horizontal pager of rich cards) -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding ShowStagesRoadmapSection}">
                <Grid ColumnDefinitions="*,Auto" Padding="0,4,0,0">
                    <Label Grid.Column="0" Text="PROGRESS ROADMAP" Style="{StaticResource LabelCaps}" />
                    <Label Grid.Column="1" Text="swipe →" Style="{StaticResource BodyMuted}" FontSize="11" />
                </Grid>

                <!--
                    Compact roadmap cards — at-a-glance only. Tap opens StageDetailPage
                    for the full long description + feelings list. 170dp track lets us
                    fit header + one-line stage caption + 2-line summary + tap hint
                    with no dead space on any stage.
                -->
                <CollectionView x:Name="StagesView" ItemsSource="{Binding Stages}"
                                SelectionMode="None"
                                HeightRequest="170">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal"
                                           ItemSpacing="12"
                                           SnapPointsType="MandatorySingle"
                                           SnapPointsAlignment="Start" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:StageRowViewModel">
                            <!--
                                DataTriggers on IsCurrent / IsPast swap the Border's
                                Stroke + StrokeThickness + Background so the current
                                stage card visibly lights up in brand indigo against
                                the muted past + future siblings. The card-level
                                Opacity binding still does the global dimming.
                            -->
                            <Border StrokeShape="RoundRectangle 14"
                                    Stroke="{StaticResource OutlineVariant}"
                                    StrokeThickness="1"
                                    Background="{StaticResource SurfaceContainerLow}"
                                    WidthRequest="260"
                                    Padding="12"
                                    Opacity="{Binding Opacity}">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsCurrent}" Value="True">
                                        <Setter Property="Stroke" Value="{StaticResource Primary}" />
                                        <Setter Property="StrokeThickness" Value="2" />
                                        <Setter Property="Background" Value="{StaticResource SurfaceContainer}" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=OpenStageCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="4">
                                    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                        <Image Grid.Column="0" Source="{Binding IconAsset}"
                                               HeightRequest="36" WidthRequest="36"
                                               Aspect="AspectFit" VerticalOptions="Center" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                            <Label Text="{Binding Name}"
                                                   Style="{StaticResource HeadlineMd}"
                                                   FontSize="15" LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding Range}"
                                                   Style="{StaticResource BodyMuted}"
                                                   FontSize="11" />
                                        </VerticalStackLayout>

                                        <!-- NOW chip — brand indigo, only when this is the active stage. -->
                                        <Border Grid.Column="2"
                                                StrokeShape="RoundRectangle 999"
                                                Background="{StaticResource Primary}"
                                                Stroke="{StaticResource Primary}"
                                                StrokeThickness="0"
                                                Padding="9,3"
                                                VerticalOptions="Center"
                                                IsVisible="{Binding IsCurrent}">
                                            <Label Text="NOW"
                                                   FontSize="10" FontAttributes="Bold"
                                                   CharacterSpacing="1.8"
                                                   TextColor="{StaticResource OnPrimary}" />
                                        </Border>

                                        <!-- REACHED chip — sage, only when stage is in the past. -->
                                        <Border Grid.Column="2"
                                                StrokeShape="RoundRectangle 999"
                                                Stroke="{StaticResource Secondary}"
                                                StrokeThickness="1"
                                                Background="Transparent"
                                                Padding="8,2"
                                                VerticalOptions="Center"
                                                IsVisible="{Binding IsPast}">
                                            <Label Text="✓ REACHED"
                                                   FontSize="9" FontAttributes="Bold"
                                                   CharacterSpacing="1.2"
                                                   TextColor="{StaticResource Secondary}" />
                                        </Border>
                                    </Grid>

                                    <Label Grid.Row="1"
                                           Text="{Binding Index, StringFormat='STAGE {0} OF 7'}"
                                           Style="{StaticResource LabelCaps}" FontSize="9" />

                                    <Label Grid.Row="2" Text="{Binding Summary}"
                                           Style="{StaticResource BodyMd}"
                                           FontSize="12"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2"
                                           VerticalOptions="Start" />

                                    <Label Grid.Row="3" Text="Tap to read more →"
                                           Style="{StaticResource BodyMuted}"
                                           FontSize="10"
                                           HorizontalOptions="End" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- EDUCATIONAL MODE notice (medical screening flagged a contraindication) -->
            <Frame Style="{StaticResource Card}"
                   BorderColor="{StaticResource Tertiary}"
                   IsVisible="{Binding IsEducationalMode}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="EDUCATIONAL MODE" Style="{StaticResource LabelCaps}"
                           TextColor="{StaticResource Tertiary}" />
                    <Label Text="Consult your doctor before starting any fasting regimen."
                           Style="{StaticResource BodyMd}" />
                    <Label Text="The timer is disabled based on your safety screening. You can still browse protocols and content."
                           Style="{StaticResource BodyMuted}" FontSize="13" />
                </VerticalStackLayout>
            </Frame>

            <!-- ACTIONS -->
            <Button Text="Start fast"
                    Command="{Binding StartFastCommand}"
                    IsVisible="{Binding StartButtonVisible}"
                    HorizontalOptions="Fill" />

            <Button Text="Start fast now"
                    Command="{Binding StartFastNowCommand}"
                    IsVisible="{Binding EatingStartButtonVisible}"
                    HorizontalOptions="Fill" />

            <Button Text="End fast"
                    Command="{Binding EndFastCommand}"
                    Style="{StaticResource DangerButton}"
                    IsVisible="{Binding IsActive}"
                    HorizontalOptions="Fill" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource Tertiary}"
                   FontSize="13"
                   IsVisible="{Binding HasError}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
