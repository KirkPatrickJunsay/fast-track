<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        These three control Android system chrome tinting (status bar, navigation bar,
        Maui.SplashTheme background). Matched to Fast Track's Surface #131313 and Primary
        #C4C0FF so the system bars blend into the app instead of advertising the .NET
        template's old indigo-violet defaults.
    -->
    <color name="colorPrimary">#131313</color>
    <color name="colorPrimaryDark">#131313</color>
    <color name="colorAccent">#C4C0FF</color>
</resources>
