<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FastTrack.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FastTrack"
    xmlns:views="clr-namespace:FastTrack.Views"
    Title="Fast Track">

    <!--
        BootPage is listed FIRST so it's the cold-launch route. It visually matches
        the system splash and immediately routes to //MainPage or //OnboardingPage
        based on the persisted profile — no flash of either before the decision lands.
    -->
    <ShellContent Title=""
                  ContentTemplate="{DataTemplate views:BootPage}"
                  Route="BootPage"
                  Shell.TabBarIsVisible="False"
                  Shell.NavBarIsVisible="False"
                  Shell.FlyoutItemIsVisible="False" />

    <TabBar>
        <ShellContent Title="Home"
                      Icon="tab_home.svg"
                      ContentTemplate="{DataTemplate local:MainPage}"
                      Route="MainPage" />
        <ShellContent Title="History"
                      Icon="tab_history.svg"
                      ContentTemplate="{DataTemplate views:HistoryPage}"
                      Route="HistoryPage" />
        <ShellContent Title="Protocols"
                      Icon="tab_protocols.svg"
                      ContentTemplate="{DataTemplate views:ProtocolsPage}"
                      Route="ProtocolsPage" />
        <ShellContent Title="Insights"
                      Icon="tab_insights.svg"
                      ContentTemplate="{DataTemplate views:InsightsPage}"
                      Route="InsightsPage" />
        <ShellContent Title="Learn"
                      Icon="tab_learn.svg"
                      ContentTemplate="{DataTemplate views:LearnPage}"
                      Route="LearnPage" />
        <ShellContent Title="Settings"
                      Icon="tab_settings.svg"
                      ContentTemplate="{DataTemplate views:SettingsPage}"
                      Route="SettingsPage" />
    </TabBar>

    <!-- Onboarding lives outside the TabBar so navigating to it hides the chrome. -->
    <ShellContent Title="Onboarding"
                  ContentTemplate="{DataTemplate views:OnboardingPage}"
                  Route="OnboardingPage"
                  Shell.TabBarIsVisible="False"
                  Shell.NavBarIsVisible="False"
                  Shell.FlyoutItemIsVisible="False" />

</Shell>
