<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FastTrack.ViewModels;assembly=FastTrack.Core"
             x:Class="FastTrack.Views.ProtocolsPage"
             x:DataType="vm:ProtocolsViewModel"
             Title="Protocols">

    <Grid Padding="20,12,20,32" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="16">

        <Label Grid.Row="0"
               Text="Choose your Protocol"
               Style="{StaticResource HeadlineLg}" />

        <Label Grid.Row="1"
               Text="Select a fasting schedule that fits your lifestyle and goals."
               Style="{StaticResource BodyMuted}" />

        <Button Grid.Row="2"
                Text="+ New custom protocol"
                Style="{StaticResource GhostButton}"
                Command="{Binding NewCustomCommand}"
                HorizontalOptions="Fill" />

        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding Items}"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:ProtocolListItem">
                    <Frame Style="{StaticResource Card}">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10"
                              ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Name}"
                                   Style="{StaticResource HeadlineMd}" />
                            <Border Grid.Row="0" Grid.Column="1"
                                    StrokeShape="RoundRectangle 999"
                                    Background="{StaticResource PrimaryContainer}"
                                    Padding="10,4"
                                    IsVisible="{Binding IsDefault}"
                                    VerticalOptions="Center">
                                <Label Text="DEFAULT"
                                       FontSize="10" FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}"
                                       CharacterSpacing="1.5" />
                            </Border>

                            <Label Grid.Row="1" Grid.ColumnSpan="2"
                                   Text="{Binding Difficulty}"
                                   Style="{StaticResource BodyMuted}"
                                   TextColor="{StaticResource Secondary}" />

                            <Label Grid.Row="2" Grid.ColumnSpan="2"
                                   Text="{Binding Subtitle}"
                                   Style="{StaticResource BodyMd}"
                                   Margin="0,4,0,0" />

                            <Label Grid.Row="3" Grid.Column="0"
                                   Text="{Binding Description}"
                                   Style="{StaticResource BodyMuted}"
                                   FontSize="13"
                                   VerticalOptions="Center" />
                            <Button Grid.Row="3" Grid.Column="1"
                                    Text="Set as default"
                                    Style="{StaticResource LinkButton}"
                                    HorizontalOptions="End"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ProtocolsViewModel}}, Path=SetDefaultCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
