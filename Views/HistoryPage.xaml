<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FastTrack.ViewModels;assembly=FastTrack.Core"
             xmlns:h="clr-namespace:FastTrack.Helpers"
             x:Class="FastTrack.Views.HistoryPage"
             x:DataType="vm:HistoryViewModel"
             Title="History">

    <Grid Padding="20,12,20,32" RowDefinitions="Auto,*" RowSpacing="16">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <Label Grid.Column="0"
                   Text="Review and edit past fasts."
                   Style="{StaticResource BodyMuted}"
                   VerticalOptions="Center" />
            <Button Grid.Column="1"
                    Text="+ Add past"
                    Style="{StaticResource GhostButton}"
                    Command="{Binding AddPastFastCommand}"
                    FontSize="12"
                    Padding="12,6"
                    MinimumHeightRequest="36" />
        </Grid>

        <VerticalStackLayout Grid.Row="1"
                             IsVisible="{Binding IsEmpty}"
                             HorizontalOptions="Center" VerticalOptions="Center"
                             Spacing="14">
            <Image Source="empty_history.svg"
                   HeightRequest="160" WidthRequest="160"
                   HorizontalOptions="Center" />
            <Label Text="No fasts yet"
                   Style="{StaticResource HeadlineMd}"
                   HorizontalTextAlignment="Center" />
            <Label Text="Finish a fast and it'll show up here — or migrate past fasts from another app."
                   Style="{StaticResource BodyMuted}"
                   HorizontalTextAlignment="Center" />
            <Button Text="+ Add past fast"
                    Style="{StaticResource GhostButton}"
                    Command="{Binding AddPastFastCommand}"
                    HorizontalOptions="Center"
                    Margin="0,6,0,0" />
        </VerticalStackLayout>

        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}"
                     RefreshColor="{StaticResource Primary}"
                     IsVisible="{Binding IsEmpty, Converter={StaticResource InverseBool}}">
        <CollectionView ItemsSource="{Binding Items}"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:HistoryItemViewModel">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems Mode="Execute">
                                <SwipeItem Text="Delete"
                                           BackgroundColor="{StaticResource Tertiary}"
                                           IconImageSource="empty_history.svg"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=SwipeDeleteCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Frame Style="{StaticResource Card}" Padding="16"
                               h:LongPress.Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=OptionsCommand}"
                               h:LongPress.CommandParameter="{Binding .}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=OpenCommand}"
                                CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                            <Image Grid.Column="0"
                                   Source="{Binding IconAsset}"
                                   HeightRequest="56" WidthRequest="56"
                                   Aspect="AspectFit"
                                   VerticalOptions="Center" />
                            <Grid Grid.Column="1"
                                  RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10" RowSpacing="4">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Title}" Style="{StaticResource HeadlineMd}" />
                            <Border Grid.Row="0" Grid.Column="1"
                                    StrokeShape="RoundRectangle 999"
                                    Background="{StaticResource SecondaryContainer}"
                                    Padding="8,3"
                                    IsVisible="{Binding GoalMet}"
                                    VerticalOptions="Center">
                                <Label Text="GOAL MET"
                                       FontSize="10" FontAttributes="Bold"
                                       CharacterSpacing="1.5"
                                       TextColor="{StaticResource Secondary}" />
                            </Border>
                            <Button Grid.Row="0" Grid.Column="2"
                                    Text="⋯"
                                    FontSize="20"
                                    WidthRequest="36" HeightRequest="36"
                                    Padding="0"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=OptionsCommand}"
                                    CommandParameter="{Binding .}" />
                            <Label Grid.Row="1" Grid.ColumnSpan="3"
                                   Style="{StaticResource BodyMd}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding DurationDisplay}" />
                                        <Span Text="  ·  " TextColor="{StaticResource OnSurfaceVariant}" />
                                        <Span Text="{Binding GoalDisplay}" TextColor="{StaticResource OnSurfaceVariant}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Label Grid.Row="2" Grid.ColumnSpan="3"
                                   Text="{Binding StartedLocal, StringFormat='Started {0}'}"
                                   Style="{StaticResource BodyMuted}"
                                   FontSize="12" />
                            </Grid>
                        </Grid>
                    </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
