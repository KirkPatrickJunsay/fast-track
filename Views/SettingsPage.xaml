<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FastTrack.ViewModels;assembly=FastTrack.Core"
             x:Class="FastTrack.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Settings">

    <ScrollView>
        <VerticalStackLayout Padding="20,12,20,32" Spacing="16">

            <!-- PROFILE -->
            <Frame Style="{StaticResource Card}">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenProfileCommand}" />
                </Frame.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Image Grid.Column="0"
                           Source="settings_profile.svg"
                           HeightRequest="56" WidthRequest="56"
                           Aspect="AspectFit"
                           VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                        <Label Text="PROFILE" Style="{StaticResource LabelCaps}" />
                        <Label Text="{Binding ProfileSummary}" Style="{StaticResource BodyMd}" />
                    </VerticalStackLayout>
                    <Label Grid.Column="2" Text="›"
                           FontSize="28" TextColor="{StaticResource OnSurfaceVariant}"
                           VerticalOptions="Center" />
                </Grid>
            </Frame>

            <!-- NOTIFICATIONS -->
            <Frame Style="{StaticResource Card}">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenNotificationsCommand}" />
                </Frame.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Image Grid.Column="0"
                           Source="settings_notifications.svg"
                           HeightRequest="56" WidthRequest="56"
                           Aspect="AspectFit"
                           VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                        <Label Text="Notifications" Style="{StaticResource HeadlineMd}" />
                        <Label Text="Local-only reminders, stage tips, quiet hours."
                               Style="{StaticResource BodyMuted}" FontSize="13" />
                    </VerticalStackLayout>
                    <Label Grid.Column="2" Text="›"
                           FontSize="28" TextColor="{StaticResource OnSurfaceVariant}"
                           VerticalOptions="Center" />
                </Grid>
            </Frame>

            <!-- TROPHIES -->
            <Frame Style="{StaticResource Card}">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenTrophiesCommand}" />
                </Frame.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Image Grid.Column="0"
                           Source="settings_trophies.svg"
                           HeightRequest="56" WidthRequest="56"
                           Aspect="AspectFit"
                           VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                        <Label Text="Trophies" Style="{StaticResource HeadlineMd}" />
                        <Label Text="Your earned badges and what's left to chase."
                               Style="{StaticResource BodyMuted}" FontSize="13" />
                    </VerticalStackLayout>
                    <Label Grid.Column="2" Text="›"
                           FontSize="28" TextColor="{StaticResource OnSurfaceVariant}"
                           VerticalOptions="Center" />
                </Grid>
            </Frame>

            <!-- INTEGRATIONS (coming) -->
            <Frame Style="{StaticResource Card}">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                    <Image Grid.Column="0"
                           Source="settings_health.svg"
                           HeightRequest="56" WidthRequest="56"
                           Aspect="AspectFit"
                           VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                        <Label Text="HEALTH INTEGRATIONS" Style="{StaticResource LabelCaps}" />
                        <Label Text="HealthKit / Health Connect"
                               Style="{StaticResource BodyMd}" />
                        <Label Text="Coming in a future update — Fast Track will stay local-only by default and only sync the metrics you opt into."
                               Style="{StaticResource BodyMuted}" FontSize="12" />
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <!-- DATA -->
            <Frame Style="{StaticResource Card}">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenDataCommand}" />
                </Frame.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Image Grid.Column="0"
                           Source="settings_data.svg"
                           HeightRequest="56" WidthRequest="56"
                           Aspect="AspectFit"
                           VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                        <Label Text="Data" Style="{StaticResource HeadlineMd}" />
                        <Label Text="Export, import, or reset your data."
                               Style="{StaticResource BodyMuted}" FontSize="13" />
                    </VerticalStackLayout>
                    <Label Grid.Column="2" Text="›"
                           FontSize="28" TextColor="{StaticResource OnSurfaceVariant}"
                           VerticalOptions="Center" />
                </Grid>
            </Frame>

            <!-- CUSTOMIZE HOME -->
            <Frame Style="{StaticResource Card}">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenCustomizeHomeCommand}" />
                </Frame.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Image Grid.Column="0"
                           Source="settings_customize.svg"
                           HeightRequest="56" WidthRequest="56"
                           Aspect="AspectFit"
                           VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                        <Label Text="Customize home" Style="{StaticResource HeadlineMd}" />
                        <Label Text="Toggle which cards appear on the Home tab."
                               Style="{StaticResource BodyMuted}" FontSize="13" />
                    </VerticalStackLayout>
                    <Label Grid.Column="2" Text="›"
                           FontSize="28" TextColor="{StaticResource OnSurfaceVariant}"
                           VerticalOptions="Center" />
                </Grid>
            </Frame>

            <!-- PRIVACY & TERMS -->
            <Frame Style="{StaticResource Card}">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenPrivacyCommand}" />
                </Frame.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Image Grid.Column="0"
                           Source="settings_privacy.svg"
                           HeightRequest="56" WidthRequest="56"
                           Aspect="AspectFit"
                           VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                        <Label Text="Privacy &amp; Terms" Style="{StaticResource HeadlineMd}" />
                        <Label Text="Local-only data, permissions, medical disclaimer."
                               Style="{StaticResource BodyMuted}" FontSize="13" />
                    </VerticalStackLayout>
                    <Label Grid.Column="2" Text="›"
                           FontSize="28" TextColor="{StaticResource OnSurfaceVariant}"
                           VerticalOptions="Center" />
                </Grid>
            </Frame>

            <!-- ADVANCED -->
            <Frame Style="{StaticResource Card}">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                    <Image Grid.Column="0"
                           Source="settings_advanced.svg"
                           HeightRequest="56" WidthRequest="56"
                           Aspect="AspectFit"
                           VerticalOptions="Start"
                           Margin="0,4,0,0" />
                    <VerticalStackLayout Grid.Column="1" Spacing="14">
                        <Label Text="ADVANCED" Style="{StaticResource LabelCaps}" />
                        <Button Text="Redo onboarding"
                                Style="{StaticResource GhostButton}"
                                Command="{Binding RedoOnboardingCommand}"
                                HorizontalOptions="Fill" />
                        <Label Text="Useful if your goals, experience, or safety screening have changed."
                               Style="{StaticResource BodyMuted}" FontSize="12" />
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <Label Text="{Binding VersionText}"
                   Style="{StaticResource BodyMuted}"
                   FontSize="11"
                   HorizontalOptions="Center"
                   Margin="0,16,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
