<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FastTrack.ViewModels;assembly=FastTrack.Core"
             xmlns:charts="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             x:Class="FastTrack.Views.InsightsPage"
             x:DataType="vm:InsightsViewModel"
             Title="Insights">

    <ScrollView>
        <VerticalStackLayout Padding="20,12,20,32" Spacing="16">

            <Label Text="Insights" Style="{StaticResource HeadlineLg}" />
            <Label Text="Your fasting story over time." Style="{StaticResource BodyMuted}" />

            <!-- WEEKLY SUMMARY -->
            <Frame Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="THIS WEEK" Style="{StaticResource LabelCaps}" />
                    <Label Text="{Binding WeeklyHoursDisplay}" Style="{StaticResource HeadlineLg}" />
                    <Label Text="{Binding WeeklyHoursLastDisplay}" Style="{StaticResource BodyMuted}" />
                    <Label Text="{Binding WeeklyDeltaDisplay}" Style="{StaticResource BodyMd}"
                           TextColor="{StaticResource Secondary}" />

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10" Margin="0,8,0,0">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="FASTS" Style="{StaticResource LabelCaps}" />
                            <Label Text="{Binding WeeklyFastsDisplay}" FontAttributes="Bold" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="STREAK" Style="{StaticResource LabelCaps}" />
                            <Label Text="{Binding WeeklyStreakDisplay}" FontAttributes="Bold" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="2">
                            <Label Text="BADGES" Style="{StaticResource LabelCaps}" />
                            <Label Text="{Binding WeeklyBadgesDisplay}" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}" Margin="0,4,0,4" />
                    <Label Text="{Binding WeeklyHighlight}"
                           Style="{StaticResource BodyMd}" FontSize="14" />
                </VerticalStackLayout>
            </Frame>

            <!-- HEATMAP -->
            <Frame Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="FASTING HEATMAP" Style="{StaticResource LabelCaps}" />
                        <Label Grid.Column="1" Text="{Binding HeatmapRangeText}"
                               Style="{StaticResource BodyMuted}" FontSize="11"
                               VerticalOptions="Center" />
                    </Grid>
                    <GraphicsView x:Name="HeatmapView" HeightRequest="140" />
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="6" Margin="0,4,0,0">
                        <Label Grid.Column="0" Text="Less" Style="{StaticResource BodyMuted}" FontSize="11" VerticalOptions="Center" />
                        <BoxView Grid.Column="2" WidthRequest="12" HeightRequest="12" CornerRadius="2" Color="{StaticResource OutlineVariant}" />
                        <BoxView Grid.Column="3" WidthRequest="12" HeightRequest="12" CornerRadius="2" Color="{StaticResource PrimaryContainer}" Margin="6,0,0,0" />
                        <BoxView Grid.Column="4" WidthRequest="12" HeightRequest="12" CornerRadius="2" Color="#7A6FD8" Margin="6,0,0,0" />
                        <BoxView Grid.Column="5" WidthRequest="12" HeightRequest="12" CornerRadius="2" Color="{StaticResource Primary}" Margin="6,0,0,0" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- RANGE SELECTOR -->
            <Frame Style="{StaticResource CardCompact}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="TRENDS · RANGE" Style="{StaticResource LabelCaps}" />
                    <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="6">
                        <Button Grid.Column="0" Text="7d"
                                Command="{Binding SelectRangeCommand}" CommandParameter="7"
                                Style="{StaticResource GhostButton}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsRange7}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource PrimaryContainer}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Grid.Column="1" Text="30d"
                                Command="{Binding SelectRangeCommand}" CommandParameter="30"
                                Style="{StaticResource GhostButton}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsRange30}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource PrimaryContainer}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Grid.Column="2" Text="90d"
                                Command="{Binding SelectRangeCommand}" CommandParameter="90"
                                Style="{StaticResource GhostButton}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsRange90}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource PrimaryContainer}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Grid.Column="3" Text="1y"
                                Command="{Binding SelectRangeCommand}" CommandParameter="365"
                                Style="{StaticResource GhostButton}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsRange365}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource PrimaryContainer}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Grid.Column="4" Text="All"
                                Command="{Binding SelectRangeCommand}" CommandParameter="all"
                                Style="{StaticResource GhostButton}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsRangeAll}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource PrimaryContainer}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- FAST DURATION -->
            <Frame Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="FAST DURATION" Style="{StaticResource LabelCaps}" />
                    <charts:ChartView x:Name="FastDurationChart" HeightRequest="160"
                                      IsVisible="{Binding HasFastDuration}" />
                    <Label Text="No completed fasts in this range yet."
                           Style="{StaticResource BodyMuted}" FontSize="12"
                           IsVisible="{Binding HasFastDuration, Converter={StaticResource InverseBool}}" />
                </VerticalStackLayout>
            </Frame>

            <!-- WEEKLY HOURS -->
            <Frame Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="WEEKLY FASTING HOURS" Style="{StaticResource LabelCaps}" />
                    <charts:ChartView x:Name="WeeklyHoursChart" HeightRequest="160"
                                      IsVisible="{Binding HasWeekly}" />
                    <Label Text="Not enough data yet."
                           Style="{StaticResource BodyMuted}" FontSize="12"
                           IsVisible="{Binding HasWeekly, Converter={StaticResource InverseBool}}" />
                </VerticalStackLayout>
            </Frame>

            <!-- WEIGHT -->
            <Frame Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="WEIGHT" Style="{StaticResource LabelCaps}" />
                    <charts:ChartView x:Name="WeightChart" HeightRequest="160"
                                      IsVisible="{Binding HasWeight}" />
                    <Label Text="Log weight to see your trend."
                           Style="{StaticResource BodyMuted}" FontSize="12"
                           IsVisible="{Binding HasWeight, Converter={StaticResource InverseBool}}" />
                </VerticalStackLayout>
            </Frame>

            <!-- WATER -->
            <Frame Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="DAILY WATER" Style="{StaticResource LabelCaps}" />
                    <charts:ChartView x:Name="WaterChart" HeightRequest="160" />
                </VerticalStackLayout>
            </Frame>

            <!-- PERSONAL BESTS -->
            <Frame Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="PERSONAL BESTS" Style="{StaticResource LabelCaps}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Longest fast" Style="{StaticResource BodyMd}" />
                        <Label Grid.Column="1" Text="{Binding LongestFastDisplay}" FontAttributes="Bold" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Longest streak" Style="{StaticResource BodyMd}" />
                        <Label Grid.Column="1" Text="{Binding LongestStreakDisplay}" FontAttributes="Bold" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Most fasts in a month" Style="{StaticResource BodyMd}" />
                        <Label Grid.Column="1" Text="{Binding MostFastsInMonthDisplay}" FontAttributes="Bold" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Highest weekly hours" Style="{StaticResource BodyMd}" />
                        <Label Grid.Column="1" Text="{Binding HighestWeeklyHoursDisplay}" FontAttributes="Bold" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Total fasts completed" Style="{StaticResource BodyMd}" />
                        <Label Grid.Column="1" Text="{Binding TotalCompletedDisplay}" FontAttributes="Bold" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
