<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FastTrack.Views.InsightsPage"
             Title="Insights">
    <VerticalStackLayout Padding="20,24" Spacing="16">
        <Label Text="Insights" Style="{StaticResource HeadlineLg}" />
        <Label Text="Trend charts, heatmap, weekly summary." Style="{StaticResource BodyMuted}" />
        <Frame Style="{StaticResource Card}" Margin="0,16,0,0">
            <VerticalStackLayout Spacing="6">
                <Label Text="COMING SOON" Style="{StaticResource LabelCaps}" />
                <Label Text="Insights ship with Epic 08." Style="{StaticResource BodyMd}" />
            </VerticalStackLayout>
        </Frame>
    </VerticalStackLayout>
</ContentPage>
