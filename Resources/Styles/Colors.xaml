<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
        FastTrack design tokens — dark-mode first.
        Mirrors DESIGN.md from the design system delivery.
    -->

    <!-- Surfaces -->
    <Color x:Key="Surface">#131313</Color>
    <Color x:Key="SurfaceBright">#393939</Color>
    <Color x:Key="SurfaceContainerLowest">#0E0E0E</Color>
    <Color x:Key="SurfaceContainerLow">#1C1B1B</Color>
    <Color x:Key="SurfaceContainer">#201F1F</Color>
    <Color x:Key="SurfaceContainerHigh">#2A2A2A</Color>
    <Color x:Key="SurfaceContainerHighest">#353534</Color>

    <!-- Text -->
    <Color x:Key="OnSurface">#E5E2E1</Color>
    <Color x:Key="OnSurfaceVariant">#C8C4D6</Color>

    <!-- Outlines -->
    <Color x:Key="Outline">#918F9F</Color>
    <Color x:Key="OutlineVariant">#474553</Color>

    <!-- Primary (Indigo) -->
    <Color x:Key="Primary">#C4C0FF</Color>
    <Color x:Key="OnPrimary">#240A9C</Color>
    <Color x:Key="PrimaryContainer">#4A3FBE</Color>
    <Color x:Key="OnPrimaryContainer">#C6C1FF</Color>

    <!-- Secondary (Sage) -->
    <Color x:Key="Secondary">#A9D38B</Color>
    <Color x:Key="OnSecondary">#173802</Color>
    <Color x:Key="SecondaryContainer">#305219</Color>
    <Color x:Key="OnSecondaryContainer">#9CC47E</Color>

    <!-- Tertiary / Error (Brick) -->
    <Color x:Key="Tertiary">#FFB3B5</Color>
    <Color x:Key="OnTertiary">#680019</Color>
    <Color x:Key="TertiaryContainer">#9A2838</Color>
    <Color x:Key="Error">#FFB4AB</Color>
    <Color x:Key="OnError">#690005</Color>
    <Color x:Key="ErrorContainer">#93000A</Color>

    <!-- Convenience brushes -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}" />
    <SolidColorBrush x:Key="SurfaceContainerBrush" Color="{StaticResource SurfaceContainer}" />
    <SolidColorBrush x:Key="SurfaceContainerHighBrush" Color="{StaticResource SurfaceContainerHigh}" />
    <SolidColorBrush x:Key="OnSurfaceBrush" Color="{StaticResource OnSurface}" />
    <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="{StaticResource OnSurfaceVariant}" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="{StaticResource PrimaryContainer}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}" />
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}" />
    <SolidColorBrush x:Key="OutlineVariantBrush" Color="{StaticResource OutlineVariant}" />

</ResourceDictionary>
