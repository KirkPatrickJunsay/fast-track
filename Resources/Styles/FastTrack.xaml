<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
        FastTrack typography + component styles.
        Manrope for display / headlines / timer, Inter for body text & labels — both variable TTFs.
        FontAttributes drives the weight via the variable axis.
    -->

    <!-- Typography styles -->
    <Style x:Key="TimerDisplay" TargetType="Label">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="48" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="CharacterSpacing" Value="-0.5" />
    </Style>

    <Style x:Key="HeadlineLg" TargetType="Label">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="CharacterSpacing" Value="-0.4" />
    </Style>

    <Style x:Key="HeadlineMd" TargetType="Label">
        <Setter Property="FontFamily" Value="Manrope" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="CharacterSpacing" Value="-0.2" />
    </Style>

    <Style x:Key="BodyLg" TargetType="Label">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <Style x:Key="BodyMd" TargetType="Label">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <Style x:Key="BodyMuted" TargetType="Label">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource OnSurfaceVariant}" />
    </Style>

    <Style x:Key="LabelCaps" TargetType="Label">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource OnSurfaceVariant}" />
        <Setter Property="CharacterSpacing" Value="2.0" />
    </Style>

    <!-- Implicit Label fallback for any unstyled label = body md -->
    <Style TargetType="Label">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <!-- ContentPage default background = surface -->
    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style TargetType="ScrollView">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
    </Style>

    <!--
        Shell chrome lives directly on AppShell.xaml (TabBarBackgroundColor /
        ForegroundColor / etc.) rather than as an implicit Style here. An implicit
        Style TargetType="Shell" in a merged ResourceDictionary throws during
        ResourceDictionary.GetOrCreateInstance on at least Android — bisected the
        crash to that single construct. Inline attributes on AppShell are simpler
        and avoid the trap.
    -->

    <!--
        Reusable ambient gradient used on Home for depth — soft indigo tint at the
        top, dissolving into Surface by ~30% of the way down. Living token so any
        page that wants the same treatment can drop it in.
    -->
    <LinearGradientBrush x:Key="HomeAmbientBackground" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="#1F1A2E" Offset="0.0" />
        <GradientStop Color="#171520" Offset="0.18" />
        <GradientStop Color="#131313" Offset="0.45" />
        <GradientStop Color="#131313" Offset="1.0" />
    </LinearGradientBrush>

    <!-- Cards -->
    <Style x:Key="Card" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceContainerLow}" />
        <Setter Property="BorderColor" Value="{StaticResource OutlineVariant}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style x:Key="CardCompact" TargetType="Frame" BasedOn="{StaticResource Card}">
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="CardSecondary" TargetType="Frame" BasedOn="{StaticResource Card}">
        <Setter Property="BackgroundColor" Value="{StaticResource SecondaryContainer}" />
        <Setter Property="BorderColor" Value="{StaticResource Secondary}" />
    </Style>

    <!-- Buttons -->
    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryContainer}" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="MinimumHeightRequest" Value="50" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="CharacterSpacing" Value="0.1" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup Name="CommonStates">
                    <VisualState Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="1.0" />
                            <Setter Property="Opacity" Value="1.0" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="0.97" />
                            <Setter Property="Opacity" Value="0.85" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.4" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="BackgroundColor" Value="{StaticResource TertiaryContainer}" />
        <Setter Property="TextColor" Value="{StaticResource Tertiary}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="MinimumHeightRequest" Value="50" />
    </Style>

    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderColor" Value="{StaticResource OutlineVariant}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style x:Key="LinkButton" TargetType="Button">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="Padding" Value="4,4" />
    </Style>

    <!-- Inputs -->
    <Style TargetType="Entry">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceContainer}" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource OnSurfaceVariant}" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceContainer}" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <Style TargetType="TimePicker">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceContainer}" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <Style TargetType="Slider">
        <Setter Property="MinimumTrackColor" Value="{StaticResource Primary}" />
        <Setter Property="MaximumTrackColor" Value="{StaticResource OutlineVariant}" />
        <Setter Property="ThumbColor" Value="{StaticResource Primary}" />
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="ProgressColor" Value="{StaticResource Primary}" />
        <Setter Property="BackgroundColor" Value="{StaticResource OutlineVariant}" />
    </Style>

    <!-- Shell tab bar -->
    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource OnSurface}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource Primary}" />
        <Setter Property="Shell.DisabledColor" Value="{StaticResource Outline}" />
        <Setter Property="Shell.UnselectedColor" Value="{StaticResource OnSurfaceVariant}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource SurfaceContainerLow}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource OnSurface}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource Primary}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource OnSurfaceVariant}" />
    </Style>

</ResourceDictionary>
